{
  "name": "ext",
  "version": "0.1",
  "manifest_version": 3,
  "description": "Browser Extension",
  "background": {
    "service_worker": "main.js"
  },
  "action": {
    "default_title": "Open"
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "permissions": [
    "sidePanel",
    "debugger",
    "tabs",
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ]
}